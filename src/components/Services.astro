---
const services = [
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'Cloud Solutions',
    desc: 'Migrate, optimize, and manage cloud infrastructure across AWS, Azure, and GCP with zero downtime and maximum efficiency.',
    tags: ['AWS', 'Azure', 'DevOps'],
    gradient: 'linear-gradient(135deg, #2563EB, #3B82F6)',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="2"/><path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
    title: 'Custom Software',
    desc: 'Bespoke web and mobile applications built with modern stacks — from MVP to enterprise-grade platforms.',
    tags: ['React', 'Node.js', 'Mobile'],
    gradient: 'linear-gradient(135deg, #7C3AED, #A78BFA)',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'Cybersecurity',
    desc: 'Comprehensive security audits, penetration testing, threat monitoring, and compliance frameworks (ISO, GDPR, PCI-DSS).',
    tags: ['Pen Testing', 'SOC 2', 'GDPR'],
    gradient: 'linear-gradient(135deg, #059669, #34D399)',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'IT Consulting',
    desc: 'Strategic technology advisory to align your IT roadmap with business goals — digital transformation done right.',
    tags: ['Strategy', 'CTO as a Service', 'Audit'],
    gradient: 'linear-gradient(135deg, #D97706, #FBBF24)',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><ellipse cx="12" cy="5" rx="9" ry="3" stroke="currentColor" stroke-width="2"/><path d="M21 12c0 1.66-4.03 3-9 3S3 13.66 3 12" stroke="currentColor" stroke-width="2"/><path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5" stroke="currentColor" stroke-width="2"/></svg>`,
    title: 'Data & Analytics',
    desc: 'Transform raw data into actionable insights with BI dashboards, data pipelines, and AI-powered analytics.',
    tags: ['Power BI', 'Python', 'ML'],
    gradient: 'linear-gradient(135deg, #0891B2, #22D3EE)',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'Managed IT Services',
    desc: 'Fully outsourced IT management — helpdesk, infrastructure monitoring, patch management, and vendor relations.',
    tags: ['24/7 NOC', 'Helpdesk', 'SLA'],
    gradient: 'linear-gradient(135deg, #E11D48, #FB7185)',
  },
];
---

<section id="services" class="services">
  <div class="container">
    <div class="services-header">
      <span class="section-label">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="2"/><path d="M3 9h18M9 21V9" stroke="currentColor" stroke-width="2"/></svg>
        What We Do
      </span>
      <h2 class="section-title">Services Built for Modern Business</h2>
      <p class="services-subtitle">
        From cloud migrations to custom software — we deliver the full stack of IT services
        your business needs to stay competitive.
      </p>
    </div>

    <div class="services-grid">
      {services.map(service => (
        <div class="service-card">
          <div class="service-icon" style={`background: ${service.gradient}`}>
            <Fragment set:html={service.icon} />
          </div>
          <h3 class="service-title">{service.title}</h3>
          <p class="service-desc">{service.desc}</p>
          <div class="service-tags">
            {service.tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
          <a href="#contact" class="service-link">
            Learn more
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    padding: 100px 0;
    background: white;
  }

  .services-header {
    text-align: center;
    max-width: 580px;
    margin: 0 auto 64px;
  }

  .services-subtitle {
    font-size: 17px;
    color: var(--muted);
    line-height: 1.7;
    margin-top: 12px;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .service-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px;
    transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .service-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: transparent;
  }

  .service-icon {
    width: 52px;
    height: 52px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    margin-bottom: 4px;
    box-shadow: 0 4px 12px rgba(0,0,0,.15);
  }

  .service-title {
    font-size: 17px;
    font-weight: 700;
    color: var(--dark);
  }

  .service-desc {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.7;
    flex: 1;
  }

  .service-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 3px 10px;
    font-size: 12px;
    font-weight: 500;
    color: var(--muted);
  }

  .service-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 600;
    color: var(--primary);
    transition: gap .2s;
    margin-top: 4px;
  }

  .service-link:hover {
    gap: 10px;
  }

  @media (max-width: 900px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 580px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
