---
const values = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'Security First',
    desc: 'Enterprise-grade security baked into every solution we deliver, protecting your business at every layer.',
    color: '#EFF6FF',
    accent: '#2563EB',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'Fast Delivery',
    desc: 'Agile development cycles that bring your ideas to market in weeks, not months, without compromising quality.',
    color: '#FFF7ED',
    accent: '#EA580C',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><path d="M12 8v4l3 3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
    title: '24/7 Support',
    desc: 'Round-the-clock technical support with dedicated engineers ready to resolve any issue at any time.',
    color: '#F0FDF4',
    accent: '#16A34A',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="2"/><path d="M3 9h18M9 21V9" stroke="currentColor" stroke-width="2"/></svg>`,
    title: 'Scalable Solutions',
    desc: 'Architecture designed to grow with your business, from startup to enterprise, without rebuilding from scratch.',
    color: '#FDF4FF',
    accent: '#7C3AED',
  },
];
---

<section id="about" class="about">
  <div class="container">
    <div class="about-grid">
      <div class="about-left">
        <span class="section-label">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><path d="M12 8v4l3 3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          Who We Are
        </span>
        <h2 class="section-title">
          A Decade of Turning Technology into Business Growth
        </h2>
        <p class="about-text">
          Founded in 2012, ITechSolutions has grown from a small software consultancy into a
          full-spectrum IT partner serving clients across the Middle East, Europe, and North America.
          We combine deep technical expertise with a relentless focus on business outcomes.
        </p>
        <p class="about-text">
          Our team of 200+ engineers, architects, and consultants delivers tailored technology
          solutions that solve real problems — measurably improving performance, security, and ROI.
        </p>

        <div class="about-certs">
          <div class="cert-badge">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="#F59E0B" stroke="#F59E0B" stroke-width="1"/></svg>
            ISO 27001 Certified
          </div>
          <div class="cert-badge">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="#F59E0B" stroke="#F59E0B" stroke-width="1"/></svg>
            AWS Advanced Partner
          </div>
          <div class="cert-badge">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="#F59E0B" stroke="#F59E0B" stroke-width="1"/></svg>
            Microsoft Gold Partner
          </div>
        </div>
      </div>

      <div class="about-right">
        <div class="values-grid">
          {values.map(v => (
            <div class="value-card" style={`--card-bg: ${v.color}; --card-accent: ${v.accent}`}>
              <div class="value-icon" style={`color: ${v.accent}; background: ${v.color}`}>
                <Fragment set:html={v.icon} />
              </div>
              <h4 class="value-title">{v.title}</h4>
              <p class="value-desc">{v.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    padding: 100px 0;
    background: var(--surface);
    position: relative;
  }

  .about::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border), transparent);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .section-title {
    font-size: clamp(26px, 3.5vw, 38px);
    font-weight: 800;
    letter-spacing: -.03em;
    margin-bottom: 20px;
    line-height: 1.15;
  }

  .about-text {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 16px;
  }

  .about-certs {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 28px;
  }

  .cert-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: white;
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 7px 14px;
    font-size: 13px;
    font-weight: 600;
    color: var(--dark-muted);
    box-shadow: var(--shadow-sm);
  }

  .values-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .value-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 24px;
    transition: transform .25s ease, box-shadow .25s ease;
  }

  .value-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .value-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 14px;
  }

  .value-title {
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--dark);
  }

  .value-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.7;
  }

  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }

  @media (max-width: 480px) {
    .values-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
