---
const footerLinks = {
  Company: ['About Us', 'Our Team', 'Careers', 'Blog', 'Press'],
  Services: ['Cloud Solutions', 'Custom Software', 'Cybersecurity', 'IT Consulting', 'Data & Analytics'],
  Support: ['Documentation', 'Help Center', 'Status Page', 'Contact Us', 'SLA Policy'],
};

const socials = [
  {
    label: 'LinkedIn',
    href: '#',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="4" cy="4" r="2" stroke="currentColor" stroke-width="2"/></svg>`,
  },
  {
    label: 'Twitter',
    href: '#',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    label: 'GitHub',
    href: '#',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="#home" class="logo">
          <div class="logo-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <span class="logo-text">ITech<strong>Solutions</strong></span>
        </a>
        <p class="brand-tagline">
          Empowering businesses through technology — from cloud and security to custom software and data intelligence.
        </p>
        <div class="socials">
          {socials.map(s => (
            <a href={s.href} class="social-btn" aria-label={s.label}>
              <Fragment set:html={s.icon} />
            </a>
          ))}
        </div>
      </div>

      <div class="footer-links">
        {Object.entries(footerLinks).map(([category, links]) => (
          <div class="footer-col">
            <h4 class="footer-col-title">{category}</h4>
            <ul>
              {links.map(link => (
                <li><a href="#" class="footer-link">{link}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="footer-bottom">
      <p class="copyright">
        &copy; {new Date().getFullYear()} ITechSolutions. All rights reserved.
      </p>
      <div class="footer-legal">
        <a href="#" class="legal-link">Privacy Policy</a>
        <span class="dot-sep"></span>
        <a href="#" class="legal-link">Terms of Service</a>
        <span class="dot-sep"></span>
        <a href="#" class="legal-link">Cookie Policy</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--dark);
    color: #94A3B8;
    padding: 72px 0 0;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1.4fr 2fr;
    gap: 80px;
    padding-bottom: 56px;
    border-bottom: 1px solid rgba(255,255,255,.08);
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
  }

  .logo-icon {
    width: 38px;
    height: 38px;
    background: var(--gradient);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-text {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 18px;
    font-weight: 500;
    color: white;
  }

  .logo-text strong { font-weight: 800; }

  .brand-tagline {
    font-size: 14px;
    line-height: 1.8;
    color: #64748B;
    max-width: 300px;
    margin-bottom: 28px;
  }

  .socials {
    display: flex;
    gap: 10px;
  }

  .social-btn {
    width: 38px;
    height: 38px;
    border-radius: var(--radius-sm);
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #94A3B8;
    transition: all .2s;
  }

  .social-btn:hover {
    background: var(--primary);
    border-color: var(--primary);
    color: white;
    transform: translateY(-2px);
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .footer-col-title {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: white;
    margin-bottom: 20px;
  }

  ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-link {
    font-size: 14px;
    color: #64748B;
    transition: color .2s;
  }

  .footer-link:hover {
    color: white;
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 0;
    gap: 16px;
    flex-wrap: wrap;
  }

  .copyright {
    font-size: 13px;
    color: #475569;
  }

  .footer-legal {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .legal-link {
    font-size: 13px;
    color: #475569;
    transition: color .2s;
  }

  .legal-link:hover { color: white; }

  .dot-sep {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: #334155;
  }

  @media (max-width: 900px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .footer-links {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 580px) {
    .footer-links {
      grid-template-columns: 1fr 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
</style>
